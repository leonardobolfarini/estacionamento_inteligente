{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],

    "rootDir": "./",
    "outDir": "./dist",

    "sourceMap": true,
    "declaration": false,

    "strict": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,

    "esModuleInterop": true,
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,

    "isolatedModules": true,
    "skipLibCheck": true,
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"],
}
