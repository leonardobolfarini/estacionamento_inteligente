  generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
  }
  datasource db {
    provider = "postgresql"
  }

  enum States {
    OCCUPIED
    FREE
  }

  enum IncidentTypes {
    STUCK_OCCUPIED
    STUCK_FREE
    FLAPPING
  }

  enum Severity {
    LOW
    MEDIUM
    HIGH
  }

  enum Status {
    OPEN
    CLOSE
    PENDING
  }

  model Sectors {
    sector_id String @id

    sensors Sensors[]
    snapshots SectorsSnapshots[]
    incidents Incidents[]
    recommendations RecommendationsLog[]
  }

  model SectorsSnapshots {
    snapshot_id Int @id @default(autoincrement())

    occupied_count Int
    free_count Int
    occupancy_rate Int

    sector Sectors @relation(fields: [sector_id], references: [sector_id])
    sector_id String

    timestamp DateTime
  }

  model Sensors {
    sensor_id String @id

    sector Sectors @relation(fields: [sector_id], references: [sector_id])
    sector_id String

    current_state States @default(FREE)
    last_state_change DateTime?

    events SensorsEvents[]
    incidents Incidents[]
  }

  model SensorsEvents {
    event_id Int @id @default(autoincrement())

    sensor Sensors @relation(fields: [sensor_id], references: [sensor_id])
    sensor_id String

    state States

    timestamp DateTime
  }

  model Incidents {
    incident_id Int @id @default(autoincrement())
    timestamp_open DateTime
    timestamp_close DateTime?
    type IncidentTypes
    severity Severity


    sector Sectors @relation(fields: [sector_id], references: [sector_id])
    sector_id String

    sensor Sensors @relation(fields: [sensor_id], references: [sensor_id])
    sensor_id String

    evidence String?
    status Status @default(PENDING)
  }

  model RecommendationsLog {
    log_id Int @id @default(autoincrement())
    timestamp DateTime

    sector Sectors @relation(fields: [recommended_sector], references: [sector_id])
    recommended_sector String

    reason String?
  }
